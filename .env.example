PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=besdong_messenger

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Mail (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password

# Dev-only: when true, `forgot-password` returns `{ otp }` in the response and skips SMTP.
# NEVER set to true in production — it exposes OTPs in plaintext API responses.
DEV_RETURN_OTP=true

# Firebase (handles Google, Facebook, Apple OAuth)
FIREBASE_PROJECT_ID=your-firebase-project-id
# Base64-encoded Firebase service account JSON: base64 -i serviceAccount.json
FIREBASE_SERVICE_ACCOUNT=base64_encoded_service_account_json

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Storage — set STORAGE_DRIVER=local for dev, s3 for production
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_PUBLIC_URL=http://localhost:3000

# MinIO (recommended for self-hosted production)
# STORAGE_DRIVER=s3
# STORAGE_ENDPOINT=http://your-minio-server:9000
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY=your_minio_access_key
# STORAGE_SECRET_KEY=your_minio_secret_key
# STORAGE_BUCKET=besdong-media
# STORAGE_CDN_URL=http://your-minio-server:9000/besdong-media

# S3 / Cloudflare R2 / DigitalOcean Spaces (alternative cloud providers)
# STORAGE_DRIVER=s3
# STORAGE_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# STORAGE_REGION=auto
# STORAGE_ACCESS_KEY=your_access_key
# STORAGE_SECRET_KEY=your_secret_key
# STORAGE_BUCKET=besdong-media
# STORAGE_CDN_URL=https://cdn.yourdomain.com